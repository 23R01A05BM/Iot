#include <ESP8266WiFi.h>

const char* ssid = "YOUR_WIFI_NAME";
const char* password = "YOUR_WIFI_PASSWORD";

const char* host = "api.thingspeak.com";

String readAPIKey = "P34F6ZQU5TOMV080";
String channelID = "3277751";

WiFiClient client;

void setup() {
  Serial.begin(115200);

  Serial.println("Connecting to WiFi...");
  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected");
}

void loop() {

  if (client.connect(host, 80)) {

    // 🔥 URL using your real channel
    String url = "/channels/3277751/feeds/last.json?api_key=P34F6ZQU5TOMV080";

    Serial.println("Requesting data from ThingSpeak...");

    client.print(String("GET ") + url + " HTTP/1.1\r\n" +
                 "Host: " + host + "\r\n" +
                 "Connection: close\r\n\r\n");

    while (client.connected() || client.available()) {
      if (client.available()) {
        String line = client.readStringUntil('\n');
        Serial.println(line);
      }
    }
  }

  client.stop();
  Serial.println("Waiting...\n");

  delay(15000); // ThingSpeak delay
}
