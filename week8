#include <ESP8266WiFi.h>
#include "ThingSpeak.h"

const char* ssid = "YOUR_WIFI_NAME";
const char* password = "YOUR_WIFI_PASSWORD";

unsigned long channelID = 3277751;
const char* readAPIKey = "P34F6ZQU5TOMV080";

WiFiClient client;

void setup() {
  Serial.begin(115200);

  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println();
  Serial.println("WiFi Connected");

  ThingSpeak.begin(client);
}

void loop() {
  long temperature = ThingSpeak.readLongField(channelID, 2, readAPIKey);

  if (ThingSpeak.getLastReadStatus() == 200) {
    Serial.print("Temperature: ");
    Serial.println(temperature);
  } else {
    Serial.println("Error reading temperature data");
  }

  delay(1000);

  long humidity = ThingSpeak.readLongField(channelID, 1, readAPIKey);

  if (ThingSpeak.getLastReadStatus() == 200) {
    Serial.print("Humidity: ");
    Serial.println(humidity);
  } else {
    Serial.println("Error reading humidity data");
  }

  Serial.println("----------------------");

  delay(15000);
}
